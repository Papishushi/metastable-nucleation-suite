FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY dotnet/ ./dotnet/
RUN dotnet publish dotnet/Metastable.Platform.Cli/Metastable.Platform.Cli.csproj \
    -c Release -r linux-x64 --self-contained true \
    -p:PublishSingleFile=true -o /out

FROM mcr.microsoft.com/dotnet/runtime-deps:8.0-jammy-chiseled AS runtime
WORKDIR /app
COPY --from=build /out/metastable-platform /app/metastable-platform
USER 1654
ENTRYPOINT ["/app/metastable-platform"]
CMD ["--self-test"]
