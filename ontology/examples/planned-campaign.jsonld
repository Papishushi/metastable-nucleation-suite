  },
  "@graph": [
    {
      "@id": "https://w3id.org/metastable-nucleation-suite/resource/specification/E09",
      "@type": ["mns:ExperimentSpecification", "mns:SimulationSpecification"],
      "mns:identifier": "E09"
    },
    {
      "@id": "https://w3id.org/metastable-nucleation-suite/resource/backend/reference-simulator",
      "@type": ["mns:Agent", "mns:HardwareBackend", "mns:SimulatorBackend"],
      "mns:identifier": "reference-simulator"
    },
    {
      "@id": "https://w3id.org/metastable-nucleation-suite/resource/campaign/e09-sequence",
      "@type": ["mns:SuiteRun", "mns:ExperimentalCampaign"],
      "mns:identifier": "e09-sequence",
      "mns:failurePolicy": "fail-fast",
      "mns:hasSubExecution": [
        {"@id": "https://w3id.org/metastable-nucleation-suite/resource/run/e09-baseline"},
        {"@id": "https://w3id.org/metastable-nucleation-suite/resource/run/e09-confirmation"}
      ]
    },
    {
      "@id": "https://w3id.org/metastable-nucleation-suite/resource/run/e09-baseline",
      "@type": ["mns:Execution", "mns:SimulationRun"],
      "mns:identifier": "e09-baseline",
      "mns:executesSpecification": {"@id": "https://w3id.org/metastable-nucleation-suite/resource/specification/E09"},
      "mns:usesBackend": {"@id": "https://w3id.org/metastable-nucleation-suite/resource/backend/reference-simulator"},
      "mns:hasExecutionStatus": {"@id": "mns:Planned"},
      "mns:trialCount": {"@value": 10, "@type": "xsd:positiveInteger"},
      "mns:randomSeed": {"@value": 11, "@type": "xsd:nonNegativeInteger"},
      "mns:partOfSuiteRun": {"@id": "https://w3id.org/metastable-nucleation-suite/resource/campaign/e09-sequence"}
    },
    {
      "@id": "https://w3id.org/metastable-nucleation-suite/resource/run/e09-confirmation",
      "@type": ["mns:Execution", "mns:SimulationRun"],
      "mns:identifier": "e09-confirmation",
      "mns:executesSpecification": {"@id": "https://w3id.org/metastable-nucleation-suite/resource/specification/E09"},
      "mns:usesBackend": {"@id": "https://w3id.org/metastable-nucleation-suite/resource/backend/reference-simulator"},
      "mns:hasExecutionStatus": {"@id": "mns:Planned"},
      "mns:trialCount": {"@value": 10, "@type": "xsd:positiveInteger"},
      "mns:randomSeed": {"@value": 12, "@type": "xsd:nonNegativeInteger"},
      "mns:partOfSuiteRun": {"@id": "https://w3id.org/metastable-nucleation-suite/resource/campaign/e09-sequence"},
      "mns:dependsOnExecution": {"@id": "https://w3id.org/metastable-nucleation-suite/resource/run/e09-baseline"}
    }
  ]
