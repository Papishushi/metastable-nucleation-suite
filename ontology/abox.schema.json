{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/metastable-nucleation-suite/schema/abox.schema.json",
  "title": "Metastable Nucleation Suite ABox",
  "type": "object",
  "required": ["@context", "@graph"],
  "properties": {
    "@context": {"oneOf": [{"type": "string"}, {"type": "object"}, {"type": "array"}]},
    "@graph": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/node"}}
  },
  "additionalProperties": false,
  "$defs": {
    "iri": {"type": "string", "format": "uri-reference", "minLength": 1},
    "idRef": {"type": "object", "required": ["@id"], "properties": {"@id": {"$ref": "#/$defs/iri"}}, "additionalProperties": false},
    "typedValue": {
      "type": "object", "required": ["@value"],
      "properties": {"@value": {}, "@type": {"type": "string"}, "@language": {"type": "string"}},
      "additionalProperties": false
    },
    "value": {
      "oneOf": [
        {"type": ["string", "number", "integer", "boolean"]},
        {"$ref": "#/$defs/idRef"},
        {"$ref": "#/$defs/typedValue"},
        {"type": "array", "minItems": 1, "items": {"oneOf": [{"type": ["string", "number", "integer", "boolean"]}, {"$ref": "#/$defs/idRef"}, {"$ref": "#/$defs/typedValue"}]}}
      ]
    },
    "node": {
      "type": "object", "required": ["@id", "@type"],
      "properties": {
        "@id": {"$ref": "#/$defs/iri"},
        "@type": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}]}
      },
      "patternProperties": {"^(?!@id$|@type$).+": {"$ref": "#/$defs/value"}},
      "additionalProperties": false
    }
  }
}
