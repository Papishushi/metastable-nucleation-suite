{
  "@context": {
    "mns": "https://w3id.org/metastable-nucleation-suite/ontology#",
    "prov": "http://www.w3.org/ns/prov#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "id": "@id",
    "type": "@type",
    "identifier": "mns:identifier",
    "title": "mns:title",
    "description": "mns:description",
    "executesSpecification": {"@id": "mns:executesSpecification", "@type": "@id"},
    "hasExecutionStatus": {"@id": "mns:hasExecutionStatus", "@type": "@id"},
    "hasTrial": {"@id": "mns:hasTrial", "@type": "@id", "@container": "@set"},
    "trialOf": {"@id": "mns:trialOf", "@type": "@id"},
    "hasObservation": {"@id": "mns:hasObservation", "@type": "@id", "@container": "@set"},
    "observationOf": {"@id": "mns:observationOf", "@type": "@id"},
    "hasResult": {"@id": "mns:hasResult", "@type": "@id", "@container": "@set"},
    "derivedFromExecution": {"@id": "mns:derivedFromExecution", "@type": "@id"},
    "hasParameter": {"@id": "mns:hasParameter", "@type": "@id", "@container": "@set"},
    "usesDataset": {"@id": "mns:usesDataset", "@type": "@id", "@container": "@set"},
    "wasExecutedBy": {"@id": "mns:wasExecutedBy", "@type": "@id", "@container": "@set"},
    "trialCount": {"@id": "mns:trialCount", "@type": "xsd:positiveInteger"},
    "randomSeed": {"@id": "mns:randomSeed", "@type": "xsd:nonNegativeInteger"},
    "startedAt": {"@id": "mns:startedAt", "@type": "xsd:dateTime"},
    "endedAt": {"@id": "mns:endedAt", "@type": "xsd:dateTime"},
    "gitCommit": "mns:gitCommit",
    "softwareVersion": "mns:softwareVersion",
    "parameterName": "mns:parameterName",
    "numericValue": {"@id": "mns:numericValue", "@type": "xsd:double"},
    "stringValue": "mns:stringValue",
    "unit": "mns:unit",
    "measurementValue": {"@id": "mns:measurementValue", "@type": "xsd:double"},
    "measurementUnit": "mns:measurementUnit",
    "resultName": "mns:resultName",
    "resultValue": {"@id": "mns:resultValue", "@type": "xsd:double"},
    "resultJson": {"@id": "mns:resultJson", "@type": "@json"},
    "conforms": {"@id": "mns:conforms", "@type": "xsd:boolean"},
    "hasValidationStatus": {"@id": "mns:hasValidationStatus", "@type": "@id"},
    "validationReport": "mns:validationReport"
  }
}
