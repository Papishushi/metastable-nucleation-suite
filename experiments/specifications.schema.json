{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Papishushi/metastable-nucleation-suite/experiments/specifications.schema.json",
  "title": "Metastable Nucleation Suite experiment specifications",
  "type": "object",
  "required": ["version", "suite", "experiments"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "suite": {"const": "metastable-nucleation-suite"},
    "experiments": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": [
          "id", "name", "objective", "hypothesis", "null_hypothesis",
          "primary_observable", "secondary_observables", "controls",
          "exclusion_rules", "stopping_rule", "analysis_plan",
          "expected_result", "escalation_criteria", "references"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^E(0[1-9]|1[0-5])$"},
          "name": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "objective": {"type": "string", "minLength": 20},
          "hypothesis": {"type": "string", "minLength": 20},
          "null_hypothesis": {"type": "string", "minLength": 20},
          "primary_observable": {"type": "string", "minLength": 2},
          "secondary_observables": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"type": "string", "minLength": 2}
          },
          "controls": {
            "type": "object",
            "required": ["positive", "negative"],
            "properties": {
              "positive": {"type": "string", "minLength": 15},
              "negative": {"type": "string", "minLength": 15}
            },
            "additionalProperties": false
          },
          "exclusion_rules": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}
          },
          "stopping_rule": {"type": "string", "minLength": 20},
          "analysis_plan": {"type": "string", "minLength": 20},
          "expected_result": {"type": "string", "minLength": 15},
          "escalation_criteria": {"type": "string", "minLength": 15},
          "references": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[A-Za-z0-9_:-]+$"}
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
