{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/metastable-nucleation-suite/catalog.schema.json",
  "title": "Metastable Nucleation Suite experiment catalog",
  "type": "object",
  "required": ["version", "suite", "experiments"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "suite": {"const": "metastable-nucleation-suite"},
    "experiments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "class", "observable", "null_prediction", "escalation"],
        "properties": {
          "id": {"type": "string", "pattern": "^E[0-9]{2}$"},
          "name": {"type": "string", "minLength": 3},
          "class": {"type": "string", "minLength": 3},
          "observable": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "null_prediction": {"type": "string", "minLength": 5},
          "escalation": {"type": "string", "minLength": 3}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
